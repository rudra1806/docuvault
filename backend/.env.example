# Environment Variables for Cloud DMS Backend
# Copy this file to .env and fill in your values

# Server Port
PORT=5000

# MongoDB Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/cloud-dms?retryWrites=true&w=majority

# JWT Secret Key (use a strong random string)
JWT_SECRET=your_jwt_secret_key_here

# JWT Token Expiry
JWT_EXPIRE=7d

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_BUCKET_NAME=docuvault-files

# CloudWatch Logging (optional - uses same AWS credentials)
CLOUDWATCH_GROUP_NAME=/docuvault/api
LOG_LEVEL=info
NODE_ENV=development

# Frontend URL for CORS (use your production URL in production)
FRONTEND_URL=http://localhost:5173

# AI Service Configuration
AI_SERVICE_URL=http://localhost:8000
